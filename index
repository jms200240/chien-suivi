<!doctype html>
<html lang="fr">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<title>Suivi du chien 🐾</title>
<meta name="description" content="Application familiale de suivi du chien : repas, promenades, croquettes et champions de la semaine, synchronisés en temps réel." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet" />
<style>
  :root {
    --radius: 20px;
    --background: oklch(0.984 0.007 95);
    --foreground: oklch(0.27 0.03 268);
    --card: #ffffff;
    --primary: oklch(0.57 0.16 256);
    --primary-foreground: oklch(0.99 0.005 250);
    --secondary: oklch(0.955 0.012 258);
    --secondary-foreground: oklch(0.3 0.03 264);
    --muted-foreground: oklch(0.53 0.03 262);
    --destructive: oklch(0.58 0.22 27);
    --border: oklch(0.91 0.012 262);
    --meal: oklch(0.66 0.17 38);
    --meal-foreground: oklch(0.99 0.01 60);
    --walk: oklch(0.6 0.14 152);
    --walk-foreground: oklch(0.99 0.01 150);
    --kibble: oklch(0.74 0.14 75);
    --kibble-foreground: oklch(0.32 0.06 60);
    --success: oklch(0.62 0.15 152);
    --success-foreground: oklch(0.99 0.01 150);
    --warning: oklch(0.78 0.15 78);
    --gradient-meal: linear-gradient(155deg, oklch(0.72 0.16 48), oklch(0.62 0.18 32));
    --gradient-walk: linear-gradient(155deg, oklch(0.66 0.13 158), oklch(0.55 0.15 148));
    --gradient-kibble: linear-gradient(155deg, oklch(0.82 0.13 82), oklch(0.72 0.15 70));
    --shadow-card: 0 1px 2px oklch(0.4 0.04 264 / 0.05), 0 8px 24px -16px oklch(0.4 0.04 264 / 0.25);
    --shadow-meal: 0 10px 24px -10px oklch(0.62 0.18 32 / 0.55);
    --shadow-walk: 0 10px 24px -10px oklch(0.55 0.15 148 / 0.5);
    --shadow-pop: 0 24px 60px -20px oklch(0.3 0.04 264 / 0.4);
  }
  * { box-sizing: border-box; border-color: var(--border); margin: 0; padding: 0; }
  body {
    background: var(--background);
    color: var(--foreground);
    font-family: "Nunito", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    -webkit-font-smoothing: antialiased;
    -webkit-tap-highlight-color: transparent;
    min-height: 100vh;
  }
  .display { font-family: "Fredoka", "Nunito", sans-serif; }
  button { font-family: inherit; cursor: pointer; border: none; background: none; color: inherit; }
  .wrap { max-width: 560px; margin: 0 auto; padding: 16px 14px 32px; }
  .card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow-card); }
  .muted { color: var(--muted-foreground); }

  /* banners */
  .banner { display:flex; align-items:center; gap:12px; border-radius: var(--radius); padding: 12px 16px; font-size:15px; font-weight:800; color:#fff; box-shadow:0 8px 16px -10px rgba(0,0,0,.4); margin-bottom:10px; animation: dcpulse 1.8s ease-in-out infinite; }
  .banner .ico { width:36px; height:36px; flex:0 0 auto; border-radius:50%; background:#fff; display:flex; align-items:center; justify-content:center; }
  @keyframes dcpulse { 0%,100%{opacity:1} 50%{opacity:.82} }

  /* header */
  header.app { display:flex; align-items:center; justify-content:space-between; margin-bottom:12px; }
  header.app .id { display:flex; align-items:center; gap:10px; }
  header.app h1 { font-size:20px; font-weight:700; line-height:1.1; }
  .iconbtn { width:36px; height:36px; border-radius:12px; background:var(--secondary); color:var(--secondary-foreground); display:flex; align-items:center; justify-content:center; transition:transform .1s; }
  .iconbtn:active { transform: scale(.92); }

  /* identity */
  .identity { padding:12px; margin-bottom:14px; }
  .identity.nudge { border:2px solid var(--warning); }
  .row { display:flex; align-items:center; justify-content:space-between; }
  .pill { border-radius:999px; padding:8px 16px; font-size:14px; font-weight:700; transition:transform .1s; }
  .pill:active { transform: scale(.95); }
  .pill.on { background:var(--primary); color:var(--primary-foreground); }
  .pill.off { background:var(--secondary); color:var(--secondary-foreground); }
  .smallbtn { border-radius:8px; border:1px solid var(--border); padding:4px 10px; font-size:12px; color:var(--muted-foreground); }

  /* grids */
  .grid2 { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
  .mb12 { margin-bottom:12px; }

  /* meal buttons */
  .meal { position:relative; display:flex; flex-direction:column; gap:10px; overflow:hidden; border-radius:18px; padding:14px; text-align:left; transition:all .2s; width:100%; border:1px solid rgba(255,255,255,.1); }
  .meal:active { transform: scale(.97); }
  .meal.unfed { background-image:var(--gradient-meal); color:var(--meal-foreground); box-shadow:var(--shadow-meal); }
  .meal.unfed:hover { transform: translateY(-2px); }
  .meal.fed { border:1px solid color-mix(in oklch, var(--success) 30%, transparent); background: color-mix(in oklch, var(--success) 10%, transparent); }
  .meal .top { display:flex; align-items:center; justify-content:space-between; }
  .meal .badge { width:44px; height:44px; flex:0 0 auto; border-radius:16px; display:flex; align-items:center; justify-content:center; background:rgba(255,255,255,.2); }
  .meal.fed .badge { background: color-mix(in oklch, var(--success) 15%, transparent); }
  .meal .ttl { font-family:"Fredoka",sans-serif; font-size:15px; font-weight:600; line-height:1.15; }
  .meal .sub { margin-top:2px; font-size:12.5px; font-weight:800; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
  .meal.unfed .sub { color: color-mix(in oklch, var(--meal-foreground) 85%, transparent); }
  .meal.fed .sub { color: var(--success); }
  .meal .undo { font-size:11px; font-weight:800; text-transform:uppercase; letter-spacing:.04em; color: color-mix(in oklch, var(--success) 70%, transparent); }

  /* walk */
  .walk { position:relative; overflow:hidden; border-radius:18px; width:100%; text-align:left; transition:all .2s; background-image:var(--gradient-walk); color:var(--walk-foreground); box-shadow:var(--shadow-walk); border:1px solid rgba(255,255,255,.1); }
  .walk:active { transform: scale(.98); }
  .walk:hover { transform: translateY(-2px); }
  .walk .inner { position:relative; display:flex; align-items:center; gap:16px; padding:16px; }
  .walk .plus { width:56px; height:56px; flex:0 0 auto; border-radius:16px; background:rgba(255,255,255,.25); display:flex; align-items:center; justify-content:center; box-shadow: inset 0 1px 4px rgba(0,0,0,.15); }
  .walk .ttl { font-family:"Fredoka",sans-serif; font-size:24px; font-weight:700; line-height:1; text-shadow:0 1px 2px rgba(0,0,0,.1); }
  .walk .sub { margin-top:4px; font-size:13px; font-weight:800; color: color-mix(in oklch, var(--walk-foreground) 90%, transparent); }
  .walk .count { flex:0 0 auto; border-radius:999px; background:rgba(255,255,255,.92); padding:6px 12px; font-size:14px; font-weight:800; color:var(--walk); }

  .walklist { margin-top:12px; display:flex; flex-direction:column; gap:6px; }
  .walkitem { display:flex; align-items:center; justify-content:space-between; border-radius:12px; background:var(--secondary); padding:8px 12px; font-size:14px; }
  .walkitem .t { color:var(--secondary-foreground); }
  .linkbtn { font-weight:800; color:var(--primary); text-decoration:underline; text-decoration-style:dotted; }
  .xbtn { color:var(--muted-foreground); transition:transform .1s; }
  .xbtn:active { transform: scale(.9); }

  /* section title */
  .sect { margin:20px 0 8px; font-size:13px; font-weight:800; text-transform:uppercase; letter-spacing:.04em; color:var(--muted-foreground); }

  /* kibble */
  .kib { padding:16px; }
  .kib.low { border:2px solid var(--destructive); background: color-mix(in oklch, var(--destructive) 5%, transparent); }
  .kib .name { font-family:"Fredoka",sans-serif; font-size:16px; font-weight:700; }
  .tag { border-radius:999px; background:var(--secondary); padding:2px 8px; font-size:11px; font-weight:700; color:var(--primary); }
  .actbtn { width:100%; display:flex; align-items:center; justify-content:center; gap:8px; border-radius:12px; padding:12px; font-size:14px; font-weight:800; transition:transform .1s; }
  .actbtn:active { transform: scale(.97); }
  .actbtn.success { background:var(--success); color:var(--success-foreground); }
  .actbtn.kibble { background-image:var(--gradient-kibble); color:var(--kibble-foreground); }

  /* trophy */
  .trophy { display:flex; flex-direction:column; align-items:center; text-align:center; padding:16px; }
  .trophy .lbl { margin-top:4px; font-size:12.5px; font-weight:700; color:var(--muted-foreground); }
  .trophy .nm { font-family:"Fredoka",sans-serif; font-size:18px; font-weight:700; }
  .trophy .cnt { font-size:12px; color:var(--muted-foreground); }

  footer { margin-top:24px; text-align:center; font-size:11.5px; line-height:1.6; color:var(--muted-foreground); }

  /* modal */
  .overlay { position:fixed; inset:0; z-index:50; display:flex; align-items:center; justify-content:center; background: color-mix(in oklch, var(--foreground) 45%, transparent); padding:16px; }
  .modal { width:100%; max-width:420px; max-height:90vh; overflow-y:auto; border-radius:var(--radius); background:var(--card); padding:24px; box-shadow:var(--shadow-pop); }
  .modal h2 { font-family:"Fredoka",sans-serif; font-size:20px; font-weight:700; margin-bottom:16px; }
  .lab { font-size:13px; font-weight:800; color:var(--muted-foreground); }
  .inp { width:100%; border-radius:12px; border:1px solid var(--border); background:var(--background); padding:10px 12px; font-size:15px; color:var(--foreground); outline:none; transition:.15s; }
  .inp:focus { border-color:var(--primary); box-shadow:0 0 0 3px color-mix(in oklch, var(--primary) 20%, transparent); }
  .modalbtns { margin-top:20px; display:flex; gap:8px; }
  .btn-secondary { flex:1; border-radius:12px; background:var(--secondary); padding:12px; font-size:14px; font-weight:700; color:var(--secondary-foreground); }
  .btn-primary { border-radius:12px; background:var(--primary); padding:12px; font-size:15px; font-weight:800; color:var(--primary-foreground); }

  /* clock */
  .clock { width:300px; border-radius:var(--radius); background:var(--card); padding:20px; box-shadow:var(--shadow-pop); }
  .clock .digits { text-align:center; margin-bottom:10px; }
  .clock .dg { border-radius:8px; padding:2px 8px; font-family:"Fredoka",sans-serif; font-size:36px; font-weight:700; }
  .clock .dg.on { background: color-mix(in oklch, var(--primary) 12%, transparent); color:var(--primary); }
  .hidden { display:none !important; }

  /* ===== SOINS ===== */
  .banner.sm { padding:7px 12px; font-size:12.5px; font-weight:700; animation:none; }
  .banner.sm .ico { width:26px; height:26px; font-size:14px; }

  .care-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
  .care-btn { display:flex; flex-direction:column; align-items:center; justify-content:center; gap:5px; padding:14px 6px; border-radius:18px; border:1px solid var(--border); background:var(--card); box-shadow:var(--shadow-card); width:100%; font-size:11px; font-weight:700; color:var(--secondary-foreground); transition:transform .12s; line-height:1.25; text-align:center; }
  .care-btn:active { transform:scale(.96); }
  .care-btn .ci { font-size:26px; }

  .season-row { display:flex; gap:8px; margin-bottom:16px; }
  .season-btn { flex:1; display:flex; align-items:center; justify-content:center; gap:6px; border-radius:12px; padding:10px 8px; font-size:12.5px; font-weight:700; border:1px solid var(--border); transition:background .15s; }
  .season-btn.active { background:var(--primary); color:var(--primary-foreground); border-color:transparent; }
  .season-btn:not(.active) { background:var(--secondary); color:var(--secondary-foreground); }

  .care-hist { display:flex; flex-direction:column; gap:8px; }
  .care-hist-item { border-radius:12px; background:var(--secondary); padding:10px 12px; }
  .care-hist-item .h-main { display:flex; justify-content:space-between; align-items:center; margin-bottom:2px; }
  .care-hist-item .h-date { font-weight:700; font-size:14px; }
  .care-hist-item .h-by { font-size:11.5px; color:var(--muted-foreground); }
  .care-hist-item .h-sub { font-size:11.5px; color:var(--muted-foreground); margin-top:2px; }
  .care-inp-lbl { display:block; font-size:11.5px; font-weight:700; color:var(--muted-foreground); margin-bottom:4px; }
</style>
</head>
<body>
<div id="app" class="wrap"><div style="display:flex;height:80vh;align-items:center;justify-content:center;color:var(--muted-foreground)">Connexion en cours… 🐾</div></div>

<script type="module">
import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
import { getDatabase, ref, onValue, get, set } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";

const firebaseConfig = {
  apiKey: "AIzaSyDogCarePublicWebKey",
  authDomain: "chien-suivi-7d81e.firebaseapp.com",
  databaseURL: "https://chien-suivi-7d81e-default-rtdb.europe-west1.firebasedatabase.app",
  projectId: "chien-suivi-7d81e",
  storageBucket: "chien-suivi-7d81e.firebasestorage.app",
  messagingSenderId: "38280363095",
  appId: "1:38280363095:web:05e5dde3f831af7c93b712",
};
const db = getDatabase(initializeApp(firebaseConfig));

const DB_PATH = "dogcare/v1/state";
const ME_KEY = "dogcare:me:v4";
const LOCAL_KEY = "dogcare:local:state";

const pad = (n) => String(n).padStart(2, "0");
const todayStr = () => { const d=new Date(); return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`; };
const mondayStr = () => { const d=new Date(); const off=(d.getDay()+6)%7; d.setDate(d.getDate()-off); return `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`; };
const fmtTime = (iso) => { if(!iso) return ""; try { return new Date(iso).toLocaleTimeString("fr-FR",{hour:"2-digit",minute:"2-digit"}); } catch { return ""; } };
const fmtDate = () => new Date().toLocaleDateString("fr-FR",{weekday:"long",day:"numeric",month:"long"});
const probableLoc = () => { const d=new Date(); const day=d.getDay(); const h=d.getHours(); if(day>=1&&day<=4) return "paris"; if(day===5) return h<12?"paris":"vailly"; if(day===6) return "vailly"; return h>=18?"paris":"vailly"; };
const esc = (s) => String(s==null?"":s).replace(/[&<>"']/g,(c)=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c]));

// ===== CARE DATE HELPERS =====
const toDateStr = (d) => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;
const fmtDateFr = (s) => { if(!s) return "—"; try { return new Date(s+"T12:00:00").toLocaleDateString("fr-FR",{day:"numeric",month:"long",year:"numeric"}); } catch { return s; } };
const addDaysStr   = (s,n) => { const d=new Date(s+"T12:00:00"); d.setDate(d.getDate()+n); return toDateStr(d); };
const addMonthsStr = (s,n) => { const d=new Date(s+"T12:00:00"); d.setMonth(d.getMonth()+n); return toDateStr(d); };
const addYearsStr  = (s,n) => { const d=new Date(s+"T12:00:00"); d.setFullYear(d.getFullYear()+n); return toDateStr(d); };

function nearestSat(dateStr) {
  const d = new Date(dateStr+"T12:00:00");
  const dow = d.getDay();
  if(dow===6) return toDateStr(d);
  const toNext = (6-dow+7)%7;
  const toPrev = 7-toNext;
  d.setDate(d.getDate()+(toNext<=toPrev?toNext:-toPrev));
  return toDateStr(d);
}
const fridayBefore = (satStr) => addDaysStr(satStr,-1);

function computeNextCare(type, baseDateStr) {
  switch(type) {
    case "vaccin":    { const due=nearestSat(addYearsStr(baseDateStr,1));  return { dueDate:due, reminderDate:addDaysStr(due,-21) }; }
    case "vermifuge": { const due=nearestSat(addMonthsStr(baseDateStr,3)); return { dueDate:due, reminderDate:fridayBefore(due) }; }
    case "tiques":    { const due=nearestSat(addDaysStr(baseDateStr,21));  return { dueDate:due, reminderDate:fridayBefore(due) }; }
  }
  return { dueDate:"", reminderDate:"" };
}

function getCareAlerts(state) {
  const today    = todayStr();
  const now      = new Date();
  const tomorrow = addDaysStr(today, 1);
  const care     = state.care || {};
  const dogName  = esc(state.dogName && state.dogName.trim() ? state.dogName : "le chien");
  const alerts   = [];

  // ===== Vaccin =====
  const vevts = care.vaccin?.events || [];
  const vrdv  = care.vaccin?.rdv   || null;
  const rdvPassed = vrdv?.date && (vrdv.date < today || (vrdv.date === today && now.getHours() >= 12));

  if(vrdv?.date && !rdvPassed) {
    // RDV futur confirmé : alertes jour-J et veille ; supprime le rappel 3 semaines
    if(vrdv.date === today)     alerts.push({ type:"vaccin_rdv", txt:`📅 RDV véto ${dogName} — aujourd'hui !` });
    else if(vrdv.date===tomorrow) alerts.push({ type:"vaccin_rdv", txt:`📅 RDV véto ${dogName} — demain !` });
    // Sinon : RDV pris mais pas encore demain → pas d'alerte spam
  } else {
    // Pas de RDV ou RDV passé → rappel 3 sem classique (cycle repart depuis date RDV passé si plus récente)
    const candidates = [];
    if(vevts.length>0) candidates.push(vevts[vevts.length-1].date);
    if(rdvPassed && vrdv?.date) candidates.push(vrdv.date);
    if(candidates.length>0) {
      const effectiveLast = candidates.slice().sort().reverse()[0];
      const next = computeNextCare("vaccin", effectiveLast);
      if(today >= next.reminderDate) {
        const days = Math.round((new Date(next.dueDate+"T12:00:00")-new Date())/86400000);
        alerts.push({ type:"vaccin", txt:`💉 Vaccin / visite annuelle${days>0?` — dans ${days} j`:` — cette semaine`}` });
      }
    }
  }

  // ===== Vermifuge =====
  const vrmevts = care.vermifuge?.events || [];
  if(vrmevts.length>0) {
    const last = vrmevts[vrmevts.length-1];
    if(last.reminderDate && today >= last.reminderDate)
      alerts.push({ type:"vermifuge", txt:`💊 Vermifuge — ce week-end à Vailly` });
  }

  // ===== Anti-tiques =====
  const td    = care.tiques || {};
  const tevts = td.events || [];
  if(td.season) {
    if(tevts.length>0) {
      const last = tevts[tevts.length-1];
      if(last.reminderDate && today >= last.reminderDate)
        alerts.push({ type:"tiques", txt:`🦟 Anti-tiques — traitement ce week-end à Vailly` });
    } else {
      alerts.push({ type:"tiques", txt:`🦟 Anti-tiques — enregistre le 1er traitement de la saison` });
    }
  } else {
    if(today >= `${new Date().getFullYear()}-03-01`)
      alerts.push({ type:"tiques", txt:`🦟 Anti-tiques — début de saison à planifier` });
  }
  return alerts;
}

const baseCare = () => ({
  vaccin:    { events:[], rdv:null },
  vermifuge: { events:[] },
  tiques:    { season:false, seasonStartDate:null, seasonEndDate:null, events:[] },
});

const baseShape = () => ({
  dogName:"", members:["","","","","",""], day:todayStr(), matin:null, soir:null,
  walks:[], lastWalkAt:null,
  kibble:{ paris:{low:false,by:null,at:null}, vailly:{low:false,by:null,at:null} },
  week:{ id:mondayStr(), feed:{}, walk:{} },
  care: baseCare(),
});

const fresh = (raw) => {
  const b = baseShape();
  const s = { ...b, ...(raw||{}) };
  let m = Array.isArray(s.members) ? s.members.slice(0,6) : [];
  while(m.length<6) m.push("");
  s.members = m;
  s.walks = Array.isArray(s.walks) ? s.walks : [];
  s.kibble = {
    paris:{ ...b.kibble.paris, ...((raw&&raw.kibble&&raw.kibble.paris)||{}) },
    vailly:{ ...b.kibble.vailly, ...((raw&&raw.kibble&&raw.kibble.vailly)||{}) },
  };
  s.week = (s.week && typeof s.week==="object") ? s.week : { id:mondayStr(), feed:{}, walk:{} };
  if(s.day!==todayStr()){ s.day=todayStr(); s.matin=null; s.soir=null; s.walks=[]; }
  if(s.week.id!==mondayStr()) s.week = { id:mondayStr(), feed:{}, walk:{} };
  if(!s.week.feed) s.week.feed={};
  if(!s.week.walk) s.week.walk={};
  // care — hydration avec rétrocompatibilité
  const rc = raw && raw.care;
  s.care = {
    vaccin:    { events: Array.isArray(rc?.vaccin?.events) ? rc.vaccin.events : [], rdv: rc?.vaccin?.rdv || null },
    vermifuge: { events: Array.isArray(rc?.vermifuge?.events) ? rc.vermifuge.events : [] },
    tiques:    {
      season:          rc?.tiques?.season          || false,
      seasonStartDate: rc?.tiques?.seasonStartDate || null,
      seasonEndDate:   rc?.tiques?.seasonEndDate   || null,
      events: Array.isArray(rc?.tiques?.events) ? rc.tiques.events : [],
    },
  };
  return s;
};

const topOf = (obj) => {
  const e = Object.entries(obj||{}).filter(([,v])=>v>0);
  if(!e.length) return { name:null, count:0 };
  const max = Math.max(...e.map((x)=>x[1]));
  const tied = e.filter((x)=>x[1]===max).map((x)=>x[0]);
  return { name: tied.length>1 ? `Égalité (${tied.join(", ")})` : tied[0], count:max };
};

async function saveShared(s){
  try { localStorage.setItem(LOCAL_KEY, JSON.stringify(s)); } catch {}
  try { await set(ref(db, DB_PATH), s); } catch(e){ console.error(e); }
}
async function mutate(fn){
  const snap = await get(ref(db, DB_PATH));
  const raw = snap.exists() ? snap.val() : baseShape();
  const next = fn(fresh(JSON.parse(JSON.stringify(raw))));
  await saveShared(next);
}

// ===== app state =====
let state = null;
let lastSync = null;
let me = "";
try { me = localStorage.getItem(ME_KEY) || ""; } catch {}
let showWho = false;
let nudge = false;
let modal = null; // {type:"settings"} | {type:"clock", idx} 
let clockState = null;
let currentPage = "home"; // "home" | "vaccin" | "vermifuge" | "tiques"

try { const c = localStorage.getItem(LOCAL_KEY); if(c) state = fresh(JSON.parse(c)); } catch {}

onValue(ref(db, DB_PATH), (snap) => {
  const raw = snap.exists() ? snap.val() : null;
  if(!raw){ const s = baseShape(); saveShared(s).then(()=>{ state=s; render(); }); }
  else { const s = fresh(raw); try{localStorage.setItem(LOCAL_KEY, JSON.stringify(s));}catch{} state=s; }
  lastSync = new Date();
  if(state && state.members.every((x)=>!x.trim()) && !modal) modal={type:"settings"};
  render();
});
setInterval(()=>render(), 60000);

// ===== actions =====
function pickMe(n){ me=n; try{localStorage.setItem(ME_KEY,n);}catch{} showWho=false; render(); }
function requireMe(){ if(!me){ nudge=true; showWho=true; setTimeout(()=>{nudge=false;render();},2500); render(); return false; } return true; }
function onMeal(slot){ if(state[slot]){ doToggleMeal(slot); return; } if(!requireMe()) return; doToggleMeal(slot); }
function doToggleMeal(slot){ mutate((s)=>{ if(s[slot]){ const by=s[slot].by; if(by) s.week.feed[by]=Math.max(0,(s.week.feed[by]||0)-1); s[slot]=null; } else { s[slot]={by:me,at:new Date().toISOString()}; s.week.feed[me]=(s.week.feed[me]||0)+1; } return s; }); }
function onWalk(){ if(!requireMe()) return; mutate((s)=>{ const iso=new Date().toISOString(); s.walks.push({by:me,at:iso}); s.lastWalkAt=iso; s.week.walk[me]=(s.week.walk[me]||0)+1; return s; }); }
function removeWalk(i){ mutate((s)=>{ const by=s.walks[i]&&s.walks[i].by; if(by) s.week.walk[by]=Math.max(0,(s.week.walk[by]||0)-1); s.walks.splice(i,1); s.lastWalkAt=s.walks.length?s.walks[s.walks.length-1].at:null; return s; }); }
function setWalkTime(i,iso){ mutate((s)=>{ if(s.walks[i]) s.walks[i].at=iso; s.walks.sort((a,b)=>+new Date(a.at)-+new Date(b.at)); s.lastWalkAt=s.walks.length?s.walks[s.walks.length-1].at:null; return s; }); }
function onKibble(loc){ if(state.kibble[loc].low){ doToggleKibble(loc); return; } if(!requireMe()) return; doToggleKibble(loc); }
function doToggleKibble(loc){ mutate((s)=>{ const c=s.kibble[loc]; s.kibble[loc]=c.low?{low:false,by:null,at:null}:{low:true,by:me,at:new Date().toISOString()}; return s; }); }
function saveSettings(dogName, members){ mutate((s)=>{ s.dogName=dogName; s.members=members.slice(0,6); return s; }); }

// ===== CARE MUTATIONS =====
async function saveCareEvent(type, event) {
  await mutate((s) => {
    if(!s.care) s.care = baseCare();
    if(!s.care[type]) s.care[type] = { events:[] };
    if(!Array.isArray(s.care[type].events)) s.care[type].events = [];
    s.care[type].events.push(event);
    s.care[type].events.sort((a,b)=>a.date.localeCompare(b.date));
    return s;
  });
}
async function toggleSeason(inSeason) {
  await mutate((s) => {
    if(!s.care) s.care = baseCare();
    if(!s.care.tiques) s.care.tiques = { season:false, events:[] };
    s.care.tiques.season = inSeason;
    const iso = new Date().toISOString();
    if(inSeason) s.care.tiques.seasonStartDate = iso;
    else         s.care.tiques.seasonEndDate   = iso;
    return s;
  });
}
async function saveVaccinRdv(dateStr) {
  await mutate((s) => {
    if(!s.care) s.care = baseCare();
    if(!s.care.vaccin) s.care.vaccin = { events:[], rdv:null };
    s.care.vaccin.rdv = { date:dateStr, by:me, at:new Date().toISOString() };
    return s;
  });
}

